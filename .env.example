# ── ОБЯЗАТЕЛЬНЫЕ ──────────────────────────────────────────────
TELEGRAM_TOKEN=ВАШ_ТОКЕН_ОТ_BOTFATHER

# Регистрация на openrouter.ai — работает из России, карта не нужна
OPENROUTER_API_KEY=ВАШ_КЛЮЧ_С_OPENROUTER.AI

# URL приложения (без слеша в конце)
# Railway: Settings → Networking → Generate Domain
# Render:  URL сервиса
WEBHOOK_URL=https://your-app.up.railway.app

# ── ОПЦИОНАЛЬНЫЕ ──────────────────────────────────────────────
# Telegram ID Bot Admin-ов (через запятую). Узнать: @userinfobot
ADMIN_IDS=123456789

# Путь к SQLite базе
# На Railway: подключи Volume и используй /data/bot_memory.db
DB_PATH=bot_memory.db

# Для заголовков OpenRouter (опционально, но рекомендуется)
SITE_URL=https://t.me/your_bot
BOT_NAME=My Telegram AI Bot

# PORT задаётся Railway/Render автоматически — не трогай
# PORT=8080
